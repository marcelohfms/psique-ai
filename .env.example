DEBOUNCE_SECONDS=3

GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

AUTH_SECRET=choose_a_strong_secret

UAZAPI_BASE_URL=https://psique.uazapi.com
UAZAPI_TOKEN=your_token_here
NOTIFY_PHONE=5511999999999
OPENAI_API_KEY=your_openai_key_here

# Supabase — shared pooler (transaction mode, port 6543)
SUPABASE_CONNECTION_STRING=postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_KEY=your_anon_or_service_role_key

# Dashboard
DASHBOARD_PASSWORD=senha_forte_aqui

# Google Sheets — ID da planilha de solicitações de documentos
# (encontrado na URL: docs.google.com/spreadsheets/d/<ID>/edit)
GOOGLE_SHEETS_DOC_ID=your_spreadsheet_id_here

# SMTP — envio de e-mail para notificar médicos
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_de_app_gmail


# Langfuse (observabilidade — self-hosted)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://langfuse.seudominio.com   # URL do seu servidor self-hosted

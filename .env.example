DEBOUNCE_SECONDS=3

GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

AUTH_SECRET=choose_a_strong_secret

OPENAI_API_KEY=your_openai_key_here

# Meta Cloud API — token permanente e ID do número de telefone
WHATSAPP_TOKEN=your_meta_permanent_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=choose_a_strong_verify_token
# App Secret do app Meta (Meta App Dashboard → Settings → Basic → App Secret).
# Quando preenchido, o /webhook valida a assinatura X-Hub-Signature-256 e rejeita
# payloads forjados. Se vazio, a validação é pulada (apenas para transição).
WHATSAPP_APP_SECRET=your_meta_app_secret_here

# Admin endpoints (/admin/pause, /admin/resume, /admin/patch-state, /admin/send-reminders)
ADMIN_SECRET=choose_a_strong_secret

# E-mail de notificações internas da clínica (agendamentos, cancelamentos, documentos)
CLINIC_NOTIFY_EMAIL=clinica@exemplo.com

# Supabase — shared pooler (transaction mode, port 6543)
SUPABASE_CONNECTION_STRING=postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_KEY=your_anon_or_service_role_key

# Dashboard
DASHBOARD_PASSWORD=senha_forte_aqui

# Google Sheets — ID da planilha de solicitações de documentos
# (encontrado na URL: docs.google.com/spreadsheets/d/<ID>/edit)
GOOGLE_SHEETS_DOC_ID=your_spreadsheet_id_here

# Google Sheets — ID da planilha de comprovantes de pagamento (aba "Pagamentos")
GOOGLE_SHEETS_PAYMENTS_ID=your_payments_spreadsheet_id_here

# Google Drive — ID da pasta para comprovantes de PIX
GOOGLE_DRIVE_PAYMENTS_FOLDER_ID=your_drive_folder_id_here

# Chave PIX da clínica (usada para validar comprovantes enviados pelos pacientes)
PIX_KEY=42006848000178

# Google Drive — ID da pasta para documentos enviados pelo paciente (exames, laudos, etc.)
GOOGLE_DRIVE_DOCUMENTS_FOLDER_ID=your_documents_folder_id_here

# SMTP — envio de e-mail para notificar médicos
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_de_app_gmail


# Chatwoot — Agent Bot inbox
CHATWOOT_BASE_URL=https://evolution-chatwoot.5pqooc.easypanel.host
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_AGENT_BOT_TOKEN=your_agent_bot_token_here
CHATWOOT_USER_TOKEN=your_user_api_token_here  # token de agente humano (perfil → Access Token no Chatwoot)
CHATWOOT_INBOX_ID=1
# Token HMAC do webhook do Chatwoot. Quando preenchido, o /chatwoot-webhook valida
# a assinatura X-Chatwoot-Signature. Se vazio, a validação é pulada.
CHATWOOT_WEBHOOK_SECRET=your_chatwoot_webhook_hmac_token_here

# Limite de mensagens de histórico enviadas ao LLM por turno (default: 30)
MAX_HISTORY_MESSAGES=30

# Langfuse (observabilidade — self-hosted)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://langfuse.seudominio.com   # URL do seu servidor self-hosted
